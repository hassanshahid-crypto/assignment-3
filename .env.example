DATABASE_URL=postgresql://username:password@localhost:5432/sveltekit_auth
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:5173

# Google OAuth: Get credentials at https://console.cloud.google.com
# Add http://localhost:5173/auth/callback/google as an authorized redirect URI
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# GitHub OAuth: Get credentials at https://github.com/settings/developers
# Add http://localhost:5173/auth/callback/github as an authorized redirect URI
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# Gmail SMTP (required for email verification & password reset)
# Use your Gmail address and an App Password (NOT your regular password)
# To create an App Password: Google Account > Security > 2-Step Verification > App Passwords
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# Google Gemini API Key (required for AI chat)
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
